generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Transaction {
  id            Int      @id @default(autoincrement())
  date          DateTime
  accountId     String
  description   String
  debit         Float?
  credit        Float?
  balance       Float
  counterparty  String?
  channel       String?
  createdAt     DateTime @default(now())
}